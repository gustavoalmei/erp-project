generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN // Administrador do sistema
  MANAGER // Gestor / Diretor
  SUPERVISOR // Líder de área / supervisor
  OPERATOR // Usuário operacional / colaborador
  VIEWER // Usuário limitado / leitura
}

enum Theme {
  light
  dark
  system
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum MovementType {
  IN
  OUT
}

model Company {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  users        UserCompany[]
  settings     SystemSettings?
  products     Product[]
  categories   Category[]
  customers    Customer[]
  sales        Sale[]
  activityLogs ActivityLog[]

  @@map("companies")
}

model UserCompany {
  userId    Int  @map("user_id")
  companyId Int  @map("company_id")
  role      Role

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@map("user_companies")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  password     String
  isSuperAdmin Boolean  @default(false) @map("is_super_admin")
  createdAt    DateTime @default(now()) @map("created_at")
  avatar       String?

  companies      UserCompany[]
  sales          Sale[]
  stockMovements StockMovement[]
  activityLogs   ActivityLog[]

  @@map("users")
}

model Category {
  id        Int     @id @default(autoincrement())
  name      String
  companyId Int     @map("company_id")

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products Product[]

  @@map("categories")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  sku         String
  categoryId  Int      @map("category_id")
  companyId   Int      @map("company_id")
  createdAt   DateTime @default(now()) @map("created_at")

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category       Category        @relation(fields: [categoryId], references: [id])
  saleItems      SaleItem[]
  stockMovements StockMovement[]

  @@unique([companyId, sku])
  @@map("products")
}

model Customer {
  id        Int     @id @default(autoincrement())
  name      String
  email     String
  phone     String
  document  String
  address   String?
  companyId Int     @map("company_id")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales   Sale[]

  @@unique([companyId, email])
  @@unique([companyId, document])
  @@map("customers")
}

model Sale {
  id         Int        @id @default(autoincrement())
  customerId Int        @map("customer_id")
  userId     Int        @map("user_id")
  companyId  Int        @map("company_id")
  total      Decimal    @db.Decimal(10, 2)
  status     SaleStatus @default(PENDING)
  createdAt  DateTime   @default(now()) @map("created_at")

  company  Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer   @relation(fields: [customerId], references: [id])
  user     User       @relation(fields: [userId], references: [id])
  items    SaleItem[]

  @@map("sales")
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int     @map("sale_id")
  productId Int     @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

model StockMovement {
  id        Int          @id @default(autoincrement())
  productId Int          @map("product_id")
  type      MovementType
  quantity  Int
  reason    String
  userId    Int          @map("user_id")
  createdAt DateTime     @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("stock_movements")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  companyId Int?     @map("company_id")
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@map("activity_logs")
}

model SystemSettings {
  companyId    Int     @id @map("company_id")
  companyName  String  @default("Minha Empresa") @map("company_name")
  logoBase64   String? @map("logo_base64")
  defaultTheme Theme   @default(system) @map("default_theme")

  colorPrimary       String @default("#f24987") @map("color_primary")
  colorPrimaryHover  String @default("#db3f78") @map("color_primary_hover")
  colorPrimaryActive String @default("#c53569") @map("color_primary_active")

  colorAccent String @default("#b2bf4b") @map("color_accent")

  colorBgPrimary   String @default("#ffffff") @map("color_bg_primary")
  colorBgSecondary String @default("#f7f7f7") @map("color_bg_secondary")
  colorSurface     String @default("#ffffff") @map("color_surface")

  colorTextPrimary   String @default("#262626") @map("color_text_primary")
  colorTextSecondary String @default("#5f6b73") @map("color_text_secondary")
  colorTextMuted     String @default("#8c959c") @map("color_text_muted")
  colorTextInverse   String @default("#ffffff") @map("color_text_inverse")

  colorBorderDefault String @default("#d9d9d9") @map("color_border_default")
  colorBorderStrong  String @default("#5f6b73") @map("color_border_strong")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("system_settings")
}
